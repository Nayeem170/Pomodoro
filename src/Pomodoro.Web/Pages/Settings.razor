@page "/settings"
@inherits SettingsPageBase

<div class="settings-page">
    <div class="settings-header">
        <h1>⚙️ Settings</h1>
        <p class="settings-tagline">Customize your pomodoro experience</p>
    </div>
    
    <TimerDurationSettings Settings="@Settings" OnChanged="MarkDirty" />
    <PreferenceSettings Settings="@Settings" OnChanged="MarkDirty" />
    <AutoStartSettings Settings="@Settings" OnChanged="MarkDirty" />
    <DataManagementSettings IsExporting="@IsExporting"
                           IsImporting="@IsImporting"
                           IsClearing="@IsClearing"
                           ImportResult="@ImportResult"
                           OnExportJson="ExportJson"
                           OnImport="HandleImport"
                           OnConfirmClearData="ConfirmClearData" />
    
    <ClearConfirmationModal IsVisible="@ShowClearConfirmation"
                            OnConfirm="ClearData"
                            OnCancel="@(() => ShowClearConfirmation = false)" />
    
    <div class="settings-actions">
        <button class="btn-save" @onclick="HandleSave" title="Save Settings" disabled="@(!HasChanges)">✓</button>
        <button class="btn-reset-defaults" @onclick="ResetToDefaults" title="Reset to Defaults" disabled="@IsAtDefaults">↺</button>
    </div>
    
    @if (ShowToast)
    {
        <div class="settings-toast">@(ToastMessage ?? "Settings saved successfully!")</div>
    }
</div>
