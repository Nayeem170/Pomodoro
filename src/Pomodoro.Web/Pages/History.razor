@page "/history"
@inherits HistoryBase
@using Pomodoro.Web.Components.History

@if (IsLoading)
{
    <div class="loading-container" role="status" aria-label="Loading">
        <div class="loading-spinner">@Constants.Layout.AppIcon</div>
        <div class="loading-text">Loading history...</div>
    </div>
}
else
{
    <div class="hist-body">
        @if (ActiveTab == HistoryTab.Daily)
        {
            <div class="period-nav">
                <div class="nav-top">
                    <div class="nav-arrows">
                        <button class="nav-arr" @onclick="GoToPreviousDay" title="Previous day" aria-label="Previous day">&#8592;</button>
                        <span class="period-lbl">@FormattedSelectedDate</span>
                        <button class="nav-arr" @onclick="GoToNextDay" title="Next day" disabled="@IsSelectedDateToday" aria-label="Next day">&#8594;</button>
                    </div>
                    <HistoryTabs ActiveTab="ActiveTab" OnTabChanged="HandleTabChanged" />
                </div>
                <button class="nav-qbtn @(IsSelectedDateToday ? "active" : "")" @onclick="GoToToday">Today</button>
            </div>

            <ErrorBoundary @ref="_dailyViewErrorBoundary">
                <ChildContent>
                    <DailyView SelectedDate="SelectedDate"
                              CurrentStats="CurrentStats"
                              Activities="CurrentActivities"
                              HasMoreActivities="HasMoreActivities"
                              IsLoadingMore="IsLoadingMore"
                              OnDateChanged="HandleDateChanged"
                              OnLoadMore="LoadMoreActivitiesAsync" />
                </ChildContent>
                <ErrorContent Context="ex">
                    <div class="section-error" role="alert">
                        <p>Failed to load daily view.</p>
                        <button class="btn btn-secondary" @onclick="() => _dailyViewErrorBoundary?.Recover()">Retry</button>
                    </div>
                </ErrorContent>
            </ErrorBoundary>
        }
        else if (ActiveTab == HistoryTab.Weekly)
        {
            <div class="period-nav">
                <div class="nav-top">
                    <div class="nav-arrows">
                        <button class="nav-arr" @onclick="GoToPreviousWeek" title="Previous week" aria-label="Previous week">&#8592;</button>
                        <span class="period-lbl">@FormattedWeekRange</span>
                        <button class="nav-arr" @onclick="GoToNextWeek" title="Next week" disabled="@IsSelectedWeekCurrent" aria-label="Next week">&#8594;</button>
                    </div>
                    <HistoryTabs ActiveTab="ActiveTab" OnTabChanged="HandleTabChanged" />
                </div>
                <button class="nav-qbtn @(IsSelectedWeekCurrent ? "active" : "")" @onclick="GoToThisWeek">This week</button>
            </div>

            <ErrorBoundary @ref="_weeklyViewErrorBoundary">
                <ChildContent>
                    <WeeklyView SelectedWeekStart="SelectedWeekStart"
                               WeeklyStats="WeeklyStats"
                               WeeklyFocusMinutes="WeeklyFocusMinutes"
                               WeeklyBreakMinutes="WeeklyBreakMinutes"
                               OnWeekChanged="HandleWeekChanged" />
                </ChildContent>
                <ErrorContent Context="ex">
                    <div class="section-error" role="alert">
                        <p>Failed to load weekly view.</p>
                        <button class="btn btn-secondary" @onclick="() => _weeklyViewErrorBoundary?.Recover()">Retry</button>
                    </div>
                </ErrorContent>
            </ErrorBoundary>
        }
    </div>
}

@code {
    private ErrorBoundary? _dailyViewErrorBoundary;
    private ErrorBoundary? _weeklyViewErrorBoundary;
}
