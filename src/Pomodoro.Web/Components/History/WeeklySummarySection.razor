@using Pomodoro.Web.Models

@if (WeeklyStats != null)
{
    <div class="stat-grid">
        <div class="sc">
            <div class="sv">@WeeklyStats.TotalPomodoroCount</div>
            <div class="sl">Pomodoros</div>
        </div>
        <div class="sc">
            <div class="sv">@FormatFocusTime(WeeklyStats.TotalFocusMinutes)</div>
            <div class="sl">Focus time</div>
        </div>
        <div class="sc">
            <div class="sv">@WeeklyStats.DailyAverageMinutes.ToString("F1")</div>
            <div class="sl">Daily avg</div>
        </div>
        <div class="sc">
            <div class="sv">@WeeklyStats.UniqueTasksWorkedOn</div>
            <div class="sl">Tasks done</div>
        </div>
    </div>
}

@code {
    [Parameter]
    public WeeklyStats? WeeklyStats { get; set; }

    private string FormatFocusTime(int minutes)
    {
        if (minutes < 60) return minutes + "m";
        var hours = minutes / 60;
        var mins = minutes % 60;
        return mins > 0 ? $"{hours}h {mins}m" : $"{hours}h";
    }
}
