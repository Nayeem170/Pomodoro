@using Pomodoro.Web.Models

@if (WeeklyStats != null)
{
    <div class="weekly-summary-section">
        <div class="section-header">
            <h2>Weekly Summary</h2>
        </div>
        <div class="weekly-stats">
            <div class="stat">
                <span class="stat-value">@WeeklyStats.TotalFocusMinutes</span>
                <span class="stat-label">Minutes This Week</span>
            </div>
            <div class="stat">
                <span class="stat-value">@WeeklyStats.TotalPomodoroCount</span>
                <span class="stat-label">Pomodoros</span>
            </div>
            <div class="stat">
                <span class="stat-value">@WeeklyStats.DailyAverageMinutes.ToString("F0")</span>
                <span class="stat-label">Daily Average</span>
            </div>
            @if (WeeklyStats.WeekOverWeekChange != 0)
            {
                <div class="stat trend @(WeeklyStats.WeekOverWeekChange > 0 ? "positive" : "negative")">
                    <span class="stat-value">@(WeeklyStats.WeekOverWeekChange > 0 ? "+" : "")@WeeklyStats.WeekOverWeekChange.ToString("F0")@Constants.UI.PercentSymbol</span>
                    <span class="stat-label">vs Last Week</span>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public WeeklyStats? WeeklyStats { get; set; }
}