@inherits WeekNavigatorBase

<div class="period-nav">
    <div class="nav-arrows">
        <button class="nav-arr" @onclick="GoToPreviousWeek" title="@Constants.History.PreviousWeekTitle" aria-label="@Constants.History.PreviousWeekTitle">&#8592;</button>
        <span class="period-lbl">@FormatWeekRange(SelectedWeekStart)</span>
        <button class="nav-arr" @onclick="GoToNextWeek" title="@Constants.History.NextWeekTitle" disabled="@IsThisWeek" aria-label="@Constants.History.NextWeekTitle">&#8594;</button>
    </div>
</div>
