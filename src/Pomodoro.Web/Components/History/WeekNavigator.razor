@inherits WeekNavigatorBase

<div class="date-navigator">
    <span class="current-date">@FormatWeekRange(SelectedWeekStart)</span>
    <div class="nav-buttons">
        <button class="nav-btn" @onclick="GoToPreviousWeek" title="@Constants.History.PreviousWeekTitle">@Constants.History.LeftArrowIcon</button>
        <button class="nav-btn today-btn" @onclick="GoToThisWeek" disabled="@IsThisWeek">@Constants.History.ThisWeekLabel</button>
        <button class="nav-btn" @onclick="GoToNextWeek" title="@Constants.History.NextWeekTitle" disabled="@IsThisWeek">@Constants.History.RightArrowIcon</button>
    </div>
</div>
