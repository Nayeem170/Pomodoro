@using Pomodoro.Web.Models
@using Pomodoro.Web.Pages

<div class="stat-grid">
    <div class="sc">
        <div class="sv">@(CurrentStats?.PomodoroCount ?? 0)</div>
        <div class="sl">Pomodoros</div>
    </div>
    <div class="sc">
        <div class="sv">@FormatFocusTime(CurrentStats?.FocusMinutes ?? 0)</div>
        <div class="sl">Focus time</div>
    </div>
    <div class="sc">
        <div class="sv">@(CurrentStats?.TasksWorkedOn ?? 0)</div>
        <div class="sl">Tasks done</div>
    </div>
    <div class="sc">
        <div class="sv">@FormatFocusTime(CurrentStats?.BreakMinutes ?? 0)</div>
        <div class="sl">Break time</div>
    </div>
</div>

@code {
    [Parameter]
    public DailyStatsSummary? CurrentStats { get; set; }

    [Inject]
    protected HistoryPagePresenterService HistoryPagePresenterService { get; set; } = default!;

    internal string FormatFocusTime(int minutes)
    {
        if (HistoryPagePresenterService == null)
        {
            return minutes.ToString();
        }
        return HistoryPagePresenterService.FormatFocusTime(minutes);
    }
}
