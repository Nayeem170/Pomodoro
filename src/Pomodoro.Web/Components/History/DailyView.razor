@using Pomodoro.Web.Models
@using Pomodoro.Web.Pages

<DailySummarySection CurrentStats="CurrentStats" />

<div class="card">
    <div class="card-hdr">
        <span class="card-title">Time distribution</span>
    </div>
    <TimeDistributionChart SelectedDate="SelectedDate" Activities="Activities ?? new()" />
    <div class="divider"></div>
    <div class="card-hdr" style="margin-bottom: 10px">
        <span class="card-title">Timeline</span>
        <span class="activity-count">@(Activities?.Count ?? 0) activities</span>
    </div>
    <TimelineSection Activities="Activities" 
                    HasMoreActivities="HasMoreActivities"
                    IsLoadingMore="IsLoadingMore"
                    OnLoadMore="OnLoadMore" />
</div>

@code {
    [Parameter]
    public DateTime SelectedDate { get; set; }
    
    [Parameter]
    public DailyStatsSummary? CurrentStats { get; set; }
    
    [Parameter]
    public List<ActivityRecord> Activities { get; set; } = new();
    
    [Parameter]
    public bool HasMoreActivities { get; set; }
    
    [Parameter]
    public bool IsLoadingMore { get; set; }
    
    [Parameter]
    public EventCallback<DateTime> OnDateChanged { get; set; }
    
    [Parameter]
    public EventCallback OnLoadMore { get; set; }
}
