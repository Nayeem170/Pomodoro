@inherits DateNavigatorBase

<div class="period-nav">
    <div class="nav-arrows">
        <button class="nav-arr" @onclick="GoToPrevious" title="Previous day" aria-label="Previous day">&#8592;</button>
        <span class="period-lbl">@FormattedDate</span>
        <button class="nav-arr" @onclick="GoToNext" title="Next day" disabled="@IsTodayAsyncValue" aria-label="Next day">&#8594;</button>
    </div>
</div>
