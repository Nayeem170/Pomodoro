@using Pomodoro.Web.Services
@using Pomodoro.Web.Services.Formatters
@using Pomodoro.Web.Models
@inject IActivityService ActivityService
@inject TimeFormatter TimeFormatter

@{
    var weekEnd = WeekStart.AddDays(7);
    var allActivities = ActivityService.GetAllActivities()
        .Where(a => a.CompletedAt.Date >= WeekStart.Date && a.CompletedAt.Date < weekEnd.Date)
        .OrderByDescending(a => a.CompletedAt)
        .Take(10)
        .ToList();
}

@if (allActivities.Count > 0)
{
    @foreach (var activity in allActivities)
    {
        string iconBg;
        if (activity.Type == SessionType.Pomodoro) iconBg = "#FAECE7";
        else if (activity.Type == SessionType.ShortBreak) iconBg = "#E1F5EE";
        else iconBg = "#E6F1FB";

        string name;
        if (activity.Type == SessionType.Pomodoro) name = "Pomodoro completed";
        else if (activity.Type == SessionType.ShortBreak) name = "Short break";
        else name = "Long break";
        var meta = string.IsNullOrEmpty(activity.TaskName)
            ? activity.CompletedAt.ToLocalTime().ToString("MMM d, h:mm tt")
            : $"{activity.TaskName} · {activity.CompletedAt.ToLocalTime().ToString("MMM d, h:mm tt")}";

        <div class="act-row">
            <div class="act-icon" style="background:@iconBg">@activity.Icon</div>
            <div class="act-info">
                <div class="act-name">@name</div>
                <div class="act-meta">@meta</div>
            </div>
            <div class="act-dur">@activity.DurationMinutes min</div>
        </div>
    }
}
else
{
    <div class="empty-chart-state">
        <span class="empty-icon">📭</span>
        <p>No activities this week</p>
    </div>
}

@code {
    [Parameter]
    public DateTime WeekStart { get; set; }
}
