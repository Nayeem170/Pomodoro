@inherits TimeDistributionChartBase

@if (Segments.Count > 0)
{
    <div class="chart-row">
        <div class="donut-wrap">
            <svg viewBox="0 0 100 100" style="width:100%;height:100%">
                <circle cx="50" cy="50" r="38" fill="none" stroke="var(--color-background-secondary)" stroke-width="10"/>
                @{
                    var circumference = 2 * Math.PI * 38;
                    var offset = 0.0;
                }
                @foreach (var seg in Segments)
                {
                    var segLen = (seg.Percentage / 100.0) * circumference;
                    var dashArray = $"{segLen:F0} {circumference:F0}";
                    var dashOffset = -offset;
                    <circle cx="50" cy="50" r="38" fill="none" stroke="@seg.Color" stroke-width="10"
                            stroke-dasharray="@dashArray" stroke-dashoffset="@dashOffset:F0"
                            transform="rotate(-90 50 50)"/>
                    offset += segLen;
                }
            </svg>
            <div class="donut-center">
                <div class="donut-val">@FormattedTotal</div>
                <div class="donut-lbl">total</div>
            </div>
        </div>
        <div class="legend">
            @foreach (var seg in Segments)
            {
                <div class="leg-row">
                    <div class="leg-dot" style="background:@seg.Color"></div>
                    <span class="leg-txt">@seg.Label <span class="leg-pct">@seg.Percentage%</span></span>
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="empty-state">
        <span class="empty-icon">📭</span>
        <p>No activities for this day</p>
    </div>
}
