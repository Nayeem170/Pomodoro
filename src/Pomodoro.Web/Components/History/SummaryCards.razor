@inherits SummaryCardsBase

<div class="summary-cards">
    <StatCard Icon="⏱️"
              Value="@FormatTime(FocusMinutes)"
              Label="focused" />
    <StatCard Icon="🍅"
              Value="@PomodoroCount.ToString()"
              Label="pomodoros" />
    <StatCard Icon="📋"
              Value="@TasksWorkedOn.ToString()"
              Label="tasks" />
</div>
