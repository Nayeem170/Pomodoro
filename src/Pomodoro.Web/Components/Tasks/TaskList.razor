@inherits TaskListBase
@using Pomodoro.Web.Models

<div class="task-card">
    <div class="task-card-header">
        <span class="task-card-title">Tasks</span>
        @if (!IsAddingTask)
        {
            <button class="task-add-btn" @onclick="StartAddTask">+ Add</button>
        }
    </div>
    
    <div class="add-task-section">
        @if (IsAddingTask)
        {
            <div class="add-task-form">
                <input type="text" 
                       @bind="NewTaskName" 
                       @bind:event="oninput"
                       @onkeydown="HandleKeyPress"
                       placeholder="Enter task name..." 
                       class="task-input" 
                       aria-label="New task name" />
                <button class="btn-icon-small btn-add" @onclick="HandleAddTask" disabled="@IsAddDisabled" title="Add" aria-label="Add task">
                    +
                </button>
                <button class="btn-icon-small btn-cancel" @onclick="CancelAddTask" title="Cancel" aria-label="Cancel">
                    x
                </button>
            </div>
        }
    </div>
    
    <div class="task-items">
        @foreach (var task in ActiveTasks)
        {
            <TaskItemComponent @key="task.Id" 
                Item="task" 
                IsSelected="task.Id == CurrentTaskId"
                OnSelect="HandleTaskSelect"
                OnComplete="HandleTaskComplete"
                OnDelete="HandleTaskDelete"
                OnUncomplete="HandleTaskUncomplete" />
        }
        
        @if (HasCompletedTasks)
        {
            <div class="completed-section">
                <h4>Completed</h4>
                @foreach (var task in CompletedTasks)
                {
                    <TaskItemComponent @key="task.Id" 
                        Item="task" 
                        IsSelected="false"
                        OnSelect="HandleTaskSelect"
                        OnComplete="HandleTaskComplete"
                        OnDelete="HandleTaskDelete"
                        OnUncomplete="HandleTaskUncomplete" />
                }
            </div>
        }
    </div>
</div>
