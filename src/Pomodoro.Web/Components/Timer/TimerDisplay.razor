@inherits TimerDisplayBase

<div class="ring-area">
    <svg width="220" height="220" viewBox="0 0 220 220">
        <circle class="ring-bg" cx="110" cy="110" r="88"/>
        <circle class="ring-fill @GetRingSessionClass()" cx="110" cy="110" r="88"
                style="stroke-dashoffset: @GetDashOffset()"/>
    </svg>
    <div class="timer-center">
        <div class="timer-time">
            @FormatTime(CurrentRemainingTime)
        </div>
        <div class="timer-mode-label">
            @GetSessionTypeLabel()
        </div>
    </div>
</div>
