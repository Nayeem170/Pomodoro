<div class="ss">
    <div class="ss-hdr">Automation</div>
    
    <div class="sr">
        <span class="sr-lbl">Auto-start pomodoros</span>
        <div class="tog @(Settings.AutoStartPomodoros ? "on" : "")" @onclick="ToggleAutoStartPomodoros">
            <div class="tog-k"></div>
        </div>
    </div>
    
    <div class="sr">
        <span class="sr-lbl">Auto-start breaks</span>
        <div class="tog @(Settings.AutoStartBreaks ? "on" : "")" @onclick="ToggleAutoStartBreaks">
            <div class="tog-k"></div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public TimerSettings Settings { get; set; } = default!;

    [Parameter]
    public EventCallback OnChanged { get; set; }

    private async Task ToggleAutoStartPomodoros()
    {
        Settings.AutoStartPomodoros = !Settings.AutoStartPomodoros;
        await OnChanged.InvokeAsync();
    }

    private async Task ToggleAutoStartBreaks()
    {
        Settings.AutoStartBreaks = !Settings.AutoStartBreaks;
        await OnChanged.InvokeAsync();
    }
}
