<div class="ss">
    <div class="ss-hdr">Automation</div>
    
    <div class="sr">
        <span class="sr-lbl">Auto-start session</span>
        <div class="tog @(Settings.AutoStartSession ? "on" : "")" @onclick="ToggleAutoStartSession">
            <div class="tog-k"></div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public TimerSettings Settings { get; set; } = default!;

    [Parameter]
    public EventCallback OnChanged { get; set; }

    private async Task ToggleAutoStartSession()
    {
        Settings.AutoStartSession = !Settings.AutoStartSession;
        await OnChanged.InvokeAsync();
    }
}
