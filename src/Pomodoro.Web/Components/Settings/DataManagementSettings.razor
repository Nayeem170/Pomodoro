<div class="ss ss-data">
    <div class="ss-hdr">Data</div>
    
    <div class="sr">
        <div>
            <div class="sr-lbl">Export data</div>
            <div class="sr-sub">Download as JSON</div>
        </div>
        <button class="sec-btn" @onclick="OnExportJson" disabled="@IsExporting" title="Export all data as JSON backup">
            @(IsExporting ? "Exporting..." : "Export")
        </button>
    </div>
    
    <div class="sr">
        <div>
            <div class="sr-lbl">Import data</div>
            <div class="sr-sub">Restore from JSON</div>
        </div>
        <div class="import-container">
            <label class="sec-btn @(IsImporting ? "disabled" : "")">
                @(IsImporting ? "Importing..." : "Import")
                <InputFile OnChange="OnImport" accept=".json" class="file-input" disabled="@IsImporting" />
            </label>
            @if (ImportResult != null)
            {
                <span class="import-result">@ImportResult</span>
            }
        </div>
    </div>
    
    <div class="sr">
        <div>
            <div class="sr-lbl">Clear all data</div>
            <div class="sr-sub">Cannot be undone</div>
        </div>
        <button class="danger-btn" @onclick="OnConfirmClearData" disabled="@IsClearing" title="Delete all data">
            @(IsClearing ? "Clearing..." : "Clear")
        </button>
    </div>
</div>

@code {
    [Parameter]
    public bool IsExporting { get; set; }

    [Parameter]
    public bool IsImporting { get; set; }

    [Parameter]
    public bool IsClearing { get; set; }

    [Parameter]
    public string? ImportResult { get; set; }

    [Parameter]
    public EventCallback OnExportJson { get; set; }

    [Parameter]
    public EventCallback<InputFileChangeEventArgs> OnImport { get; set; }

    [Parameter]
    public EventCallback OnConfirmClearData { get; set; }
}
