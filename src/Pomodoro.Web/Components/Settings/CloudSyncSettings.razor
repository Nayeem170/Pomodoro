@using Pomodoro.Web.Services
@inject ICloudSyncService CloudSyncService
@inject ILogger<CloudSyncSettings> Logger

<div class="ss ss-data">
    <div class="ss-hdr">Cloud Sync</div>

    @if (!CloudSyncService.IsConnected)
    {
        <div class="sr">
            <div>
                <div class="sr-lbl">Google Drive</div>
                <div class="sr-sub">Sync across devices</div>
            </div>
            <button class="sec-btn" @onclick="Connect" disabled="@_isConnecting">
                @(_isConnecting ? "Connecting..." : "Connect")
            </button>
        </div>
    }
    else
    {
        <div class="sr">
            <div>
                <div class="sr-lbl">Google Drive</div>
                <div class="sr-sub">Last synced @FormatLastSynced</div>
            </div>
            <div class="sync-actions">
                <button class="sec-btn" @onclick="SyncNow" disabled="@_isSyncing">
                    @(_isSyncing ? "Syncing..." : "Sync")
                </button>
                <button class="danger-btn" @onclick="Disconnect" disabled="@_isSyncing">Disconnect</button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public EventCallback<string> OnShowToast { get; set; }

    private bool _isConnecting;
    private bool _isSyncing;
    private bool _isDisconnecting;

    protected override void OnInitialized()
    {
        CloudSyncService.OnSyncStatusChanged += OnSyncStatusChanged;
    }

    public void Dispose()
    {
        CloudSyncService.OnSyncStatusChanged -= OnSyncStatusChanged;
    }

    private string FormatLastSynced => CloudSyncService.LastSyncedAt.HasValue
        ? CloudSyncService.LastSyncedAt.Value.ToLocalTime().ToString("g")
        : "Never";

    private async Task ShowToast(string message)
    {
        await OnShowToast.InvokeAsync(message);
    }

    private async Task Connect()
    {
        _isConnecting = true;
        StateHasChanged();

        try
        {
            var clientId = CloudSyncService.ClientId ?? Constants.Sync.DefaultClientId;
            var success = await CloudSyncService.ConnectAsync(clientId);
            if (success)
            {
                await ShowToast(Constants.SyncMessages.Connected);
            }
            else
            {
                await ShowToast(Constants.SyncMessages.AuthFailed);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to connect Google Drive");
            await ShowToast(Constants.SyncMessages.InitFailed);
        }
        finally
        {
            _isConnecting = false;
            StateHasChanged();
        }
    }

    private async Task SyncNow()
    {
        _isSyncing = true;
        StateHasChanged();

        try
        {
            var result = await CloudSyncService.SyncNowAsync();

            if (result.Success)
            {
                string message;
                if (result.Action == SyncAction.Pushed)
                    message = Constants.SyncMessages.SyncPushSuccess;
                else if (result.Action == SyncAction.Pulled)
                    message = string.Format(Constants.SyncMessages.SyncPullSuccess,
                        result.ActivitiesImported, result.TasksImported);
                else
                    message = Constants.SyncMessages.AlreadyUpToDate;
                await ShowToast(message);
            }
            else if (result.ErrorMessage == Constants.SyncMessages.ReconnectRequired)
            {
                var clientId = CloudSyncService.ClientId ?? Constants.Sync.DefaultClientId;
                var connected = await CloudSyncService.ConnectAsync(clientId);
                if (connected)
                {
                    result = await CloudSyncService.SyncNowAsync();
                    if (result.Success)
                    {
                        string message;
                        if (result.Action == SyncAction.Pushed)
                            message = Constants.SyncMessages.SyncPushSuccess;
                        else if (result.Action == SyncAction.Pulled)
                            message = string.Format(Constants.SyncMessages.SyncPullSuccess,
                                result.ActivitiesImported, result.TasksImported);
                        else
                            message = Constants.SyncMessages.AlreadyUpToDate;
                        await ShowToast(message);
                    }
                    else
                    {
                        await ShowToast(result.ErrorMessage ?? Constants.SyncMessages.SyncFailed);
                    }
                }
                else
                {
                    await ShowToast(Constants.SyncMessages.AuthFailed);
                }
            }
            else
            {
                await ShowToast(result.ErrorMessage ?? Constants.SyncMessages.SyncFailed);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Manual sync failed");
            await ShowToast(Constants.SyncMessages.SyncFailed);
        }
        finally
        {
            _isSyncing = false;
            StateHasChanged();
        }
    }

    private async Task Disconnect()
    {
        _isSyncing = true;
        _isDisconnecting = true;
        StateHasChanged();

        try
        {
            await CloudSyncService.DisconnectAsync();
            await ShowToast(Constants.SyncMessages.Disconnected);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to disconnect Google Drive");
            await ShowToast(Constants.SyncMessages.SyncFailed);
        }
        finally
        {
            _isSyncing = false;
            _isDisconnecting = false;
            StateHasChanged();
        }
    }

    private void OnSyncStatusChanged()
    {
        if (_isDisconnecting) return;

        InvokeAsync(StateHasChanged);
    }
}
