@inherits ConsentModalBase
@using Pomodoro.Web.Models
@using Pomodoro.Web.Services

@if (IsVisible)
{
    <div class="consent-modal-overlay" role="dialog" aria-modal="true" aria-labelledby="consent-title">
        <div class="consent-modal">
            <div class="consent-body">
                <div class="consent-icon-wrap">
                    @GetIcon()
                </div>
                <div class="consent-header">
                    <h2 id="consent-title">@GetTitle()</h2>
                </div>
                
                <p class="consent-message">@GetMessage()</p>
                
                <div class="consent-options">
                    @if (Options?.Count > 0)
                    {
                        @RenderOptions
                    }
                </div>
            </div>
            
            <div class="consent-footer">
                <div class="auto-continue-row">
                    <div class="spinner"></div>
                    <span>Auto-continuing in <strong>@CountdownSeconds</strong> seconds...</span>
                </div>
                <div class="consent-progress-track">
                    <div class="consent-progress-fill" style="width: @GetProgressPercentage()%"></div>
                </div>
            </div>
        </div>
    </div>
}
